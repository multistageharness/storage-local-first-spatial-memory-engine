# Defaults for integration/repo.cli.ts — copy to .env and edit.
# All optional; the CLI prompts with these as the pre-filled values.

# Git repo the CLI ingests (http(s) or git@).
REPO_URL=https://github.com/mui/material-ui.git

# Repo-relative subtree to sparse-checkout + ingest. Keep it scoped —
# the whole repo is rarely what you want to RAG over.
SPARSE_PATH=packages/mui-material/src

# Graph name (entity-level contextual firewall) the atoms land under.
GRAPH=material-ui

# Optional include/exclude regexes layered on the built-in extension + test +
# size rules. Both default to EMPTY (ingest the whole subtree). Tested against
# the forward-slashed clone-relative path (== each atom's originFile). Each
# distinct filter set gets its own DB. Examples:
#   FILTER=/Button/                  ingest only the Button family
#   IGNORE=/(Unstable_|legacy)/      drop unstable/legacy subtrees
FILTER=
IGNORE=
