{
  "name": "spatial-memory-engine-org",
  "version": "0.2.0",
  "description": "Org-scale local-first spatial memory engine (demo002): federated demo001 SQLite kernels — shard-per-graph, hybrid FTS5 retrieval (trigram+unicode61+optional vectors), RRF federation, checkpointed Confluence/Git connectors, CRDT epoch GC + partial replication",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test \"dist/__test__/*.test.js\"",
    "eval": "npm run build && tsx integration/eval-gate.ts",
    "eval:jury": "npm run build && tsx integration/eval-gate.ts --jury",
    "benchmark": "npm run build && tsx integration/benchmark-gate.ts",
    "benchmark:jury": "npm run build && tsx integration/benchmark-gate.ts --jury",
    "benchmark:react": "npm run build && tsx integration/benchmark-react-gate.ts",
    "rag-at-scale": "npm run build && tsx integration/rag-at-scale.ts",
    "rag-at-scale:big": "npm run build && tsx integration/rag-at-scale.ts --docs 5000 --queries 200",
    "integration": "npm run build && tsx integration/codebase-rag.ts && tsx integration/multi-writer-concurrency.ts && tsx integration/crdt-replica-sync.ts",
    "integration:codebase-rag": "npm run build && tsx integration/codebase-rag.ts",
    "integration:multi-writer": "npm run build && tsx integration/multi-writer-concurrency.ts",
    "integration:replica-sync": "npm run build && tsx integration/crdt-replica-sync.ts",
    "integration:repo": "npm run build && tsx integration/repo.ts",
    "cli:repo": "npm run build && tsx integration/repo.cli.ts",
    "integration:codebase-fs": "npm run build && tsx integration/codebase-fs.ts",
    "integration:fs-filters": "npm run build && tsx integration/fs-filters.ts",
    "eval:federated": "npm run build && tsx integration/eval-gate-federated.ts",
    "benchmark:org": "npm run build && tsx integration/benchmark-org-gate.ts",
    "perf": "npm run build && tsx integration/perf-gate.ts",
    "org-ingest": "npm run build && tsx integration/org-ingest.ts",
    "org-incremental": "npm run build && tsx integration/org-incremental.ts",
    "rag-at-org-scale": "npm run build && tsx integration/rag-at-org-scale.ts",
    "rag-at-org-scale:big": "npm run build && tsx integration/rag-at-org-scale.ts --shards 500 --queries 1000 --recall-only",
    "integration:multi-writer-org": "npm run build && tsx integration/multi-writer-org.ts",
    "integration:federated-replica-sync": "npm run build && tsx integration/federated-replica-sync.ts",
    "integration:confluence": "npm run build && tsx integration/confluence-gate.ts",
    "integration:repo-org": "npm run build && tsx integration/repo-org-gate.ts",
    "soak:smoke": "npm run build && tsx integration/soak.ts --minutes 1 --shards 16"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
